    <year>2021</year>
    <publisher>Chapman and Hall/CRC Press</publisher>
    <note>
      <p>
        Citation exports are available as <url href="https://www.protectlab.org/meta-analysis-in-r/data/citation.bib">BibTeX</url> and <url href="https://www.protectlab.org/meta-analysis-in-r/data/citation.ris">RIS</url>.
      </p>
    </note>
  </biblio>
  <biblio xml:id="pretext-guide" type="bibtex">
